{
  "name": "discord",
  "version": "1.0.0",
  "description": "",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "prisma migrate deploy && node dist/index.js",
    "build": "tsup src/index.ts --minify",
    "typecheck": "tsc --noEmit",
    "db:push": "prisma db push",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "test-render": "tsx src/scripts/test-render.ts",
    "biome": "biome check",
    "biome:fix": "biome check --fix",
    "check": "pnpm typecheck && pnpm biome",
    "generate:data": "tsx src/scripts/generate-random-data.ts"
  },
  "dependencies": {
    "@napi-rs/canvas": "^0.1.97",
    "@prisma/client": "^6.19.3",
    "discord.js": "^14.26.2",
    "dotenv": "^17.4.1",
    "prisma": "^6.19.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@types/node": "^20.19.39",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "private": true
}
